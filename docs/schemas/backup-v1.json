{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recordwell.app/schemas/backup-v1.json",
  "title": "RecordWell Backup File Format",
  "description": "Self-documenting JSON backup format for RecordWell medical records app. Supports optional Argon2id + AES-256-GCM encryption.",
  "type": "object",
  "required": ["formatName", "formatVersion", "generator", "encrypted", "checksum"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URL for validation (informational)"
    },
    "formatName": {
      "type": "string",
      "const": "RecordWell Backup",
      "description": "Human-readable format identifier"
    },
    "formatVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Semantic version for compatibility checking (e.g., '1.0')"
    },
    "generator": {
      "type": "string",
      "description": "App name/version that created this backup (e.g., 'RecordWell/1.0.0 (iOS)')"
    },
    "encrypted": {
      "type": "boolean",
      "description": "Whether the payload is encrypted"
    },
    "checksum": {
      "$ref": "#/$defs/checksum"
    },
    "encryption": {
      "$ref": "#/$defs/encryption",
      "description": "Encryption parameters (present only if encrypted=true)"
    },
    "ciphertext": {
      "type": "string",
      "contentEncoding": "base64",
      "description": "Base64-encoded encrypted payload (present only if encrypted=true)"
    },
    "data": {
      "$ref": "#/$defs/backupPayload",
      "description": "Raw backup payload (present only if encrypted=false)"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "encrypted": { "const": true } }
      },
      "then": {
        "required": ["encryption", "ciphertext"],
        "properties": {
          "data": { "not": {} }
        }
      }
    },
    {
      "if": {
        "properties": { "encrypted": { "const": false } }
      },
      "then": {
        "required": ["data"],
        "properties": {
          "encryption": { "not": {} },
          "ciphertext": { "not": {} }
        }
      }
    }
  ],
  "$defs": {
    "checksum": {
      "type": "object",
      "description": "Integrity checksum for corruption detection before decryption",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "SHA-256",
          "description": "Hash algorithm used"
        },
        "value": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Base64-encoded hash. For encrypted: SHA-256 of AES-256-GCM combined bytes (nonce + ciphertext + tag). For unencrypted: SHA-256 of JSON-serialized data object (UTF-8 bytes)."
        }
      }
    },
    "encryption": {
      "type": "object",
      "description": "Encryption parameters following JWE-like structure with Argon2id KDF",
      "required": ["algorithm", "kdf", "nonce", "tag"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "AES-256-GCM",
          "description": "Encryption algorithm"
        },
        "kdf": {
          "$ref": "#/$defs/kdf"
        },
        "nonce": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Base64-encoded 12-byte nonce/IV"
        },
        "tag": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Base64-encoded 16-byte authentication tag"
        }
      }
    },
    "kdf": {
      "type": "object",
      "description": "Argon2id key derivation function parameters",
      "required": ["algorithm", "version", "salt", "memory", "iterations", "parallelism", "keyLength"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "Argon2id",
          "description": "KDF algorithm"
        },
        "version": {
          "type": "integer",
          "const": 19,
          "description": "Argon2id version (19 = 0x13)"
        },
        "salt": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Base64-encoded 16-byte random salt"
        },
        "memory": {
          "type": "integer",
          "minimum": 1048576,
          "description": "Memory cost in bytes (default: 67108864 = 64 MB)"
        },
        "iterations": {
          "type": "integer",
          "minimum": 1,
          "description": "Time cost / iterations (default: 3)"
        },
        "parallelism": {
          "type": "integer",
          "minimum": 1,
          "description": "Parallelism / lanes (default: 1)"
        },
        "keyLength": {
          "type": "integer",
          "const": 32,
          "description": "Output key length in bytes (32 for AES-256)"
        }
      }
    },
    "backupPayload": {
      "type": "object",
      "description": "Decrypted backup payload containing all user data",
      "required": ["exportedAt", "appVersion", "metadata", "persons", "records", "providers"],
      "properties": {
        "exportedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when backup was created"
        },
        "appVersion": {
          "type": "string",
          "description": "App version that created this backup"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        },
        "persons": {
          "type": "array",
          "items": { "$ref": "#/$defs/person" },
          "description": "All family members"
        },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/medicalRecord" },
          "description": "All medical records"
        },
        "providers": {
          "type": "array",
          "items": { "$ref": "#/$defs/provider" },
          "description": "All healthcare providers"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Summary counts (inside encrypted payload for privacy)",
      "required": ["personCount", "recordCount", "providerCount"],
      "properties": {
        "personCount": { "type": "integer", "minimum": 0 },
        "recordCount": { "type": "integer", "minimum": 0 },
        "providerCount": { "type": "integer", "minimum": 0 }
      }
    },
    "person": {
      "type": "object",
      "description": "Family member data",
      "required": ["id", "name", "labels", "createdAt", "updatedAt"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier"
        },
        "name": {
          "type": "string",
          "description": "Person's name"
        },
        "dateOfBirth": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Date of birth (optional)"
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Labels/tags (e.g., 'child', 'spouse')"
        },
        "notes": {
          "type": ["string", "null"],
          "description": "General notes about this person"
        },
        "gender": {
          "type": ["string", "null"],
          "description": "Gender identity (free text, optional)"
        },
        "bloodType": {
          "type": ["string", "null"],
          "description": "Blood type (e.g., 'A+', 'O-', optional)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "medicalRecord": {
      "type": "object",
      "description": "Medical record with FHIR-typed content",
      "required": ["id", "personId", "recordType", "schemaVersion", "contentJSON", "createdAt", "updatedAt", "version"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "personId": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the person this record belongs to"
        },
        "recordType": {
          "type": "string",
          "description": "FHIR record type (e.g., 'immunization', 'condition')"
        },
        "schemaVersion": {
          "type": "integer",
          "minimum": 1,
          "description": "Schema version for forward compatibility"
        },
        "contentJSON": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Base64-encoded JSON of the typed record content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Version number for edit history"
        },
        "previousVersionId": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "ID of previous version (for edit tracking)"
        }
      }
    },
    "provider": {
      "type": "object",
      "description": "Healthcare provider data",
      "required": ["id", "personId", "createdAt", "updatedAt", "version"],
      "anyOf": [
        { "required": ["name"], "properties": { "name": { "type": "string" } } },
        { "required": ["organization"], "properties": { "organization": { "type": "string" } } }
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier"
        },
        "personId": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the person this provider belongs to"
        },
        "name": {
          "type": ["string", "null"],
          "description": "Provider's name (individual practitioner)"
        },
        "organization": {
          "type": ["string", "null"],
          "description": "Organization or facility name"
        },
        "specialty": {
          "type": ["string", "null"],
          "description": "Medical specialty (e.g., 'Pediatrics', 'Cardiology')"
        },
        "phone": {
          "type": ["string", "null"],
          "description": "Contact phone number"
        },
        "address": {
          "type": ["string", "null"],
          "description": "Physical address"
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Additional notes about this provider"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Version number for edit history"
        },
        "previousVersionId": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "ID of previous version (for edit tracking)"
        }
      }
    }
  }
}
